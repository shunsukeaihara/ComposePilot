# Copy to /etc/composepilot/composepilot.env and chmod 600.
# Prefer the *_FILE form so the base64 key is stored in a root-owned file.
COMPOSEPILOT_MASTER_KEY_FILE=/etc/composepilot/master_key

# Optional overrides:
# COMPOSEPILOT_LISTEN=:8080
# COMPOSEPILOT_DATA_DIR=/var/lib/composepilot
# COMPOSEPILOT_WORKSPACE=/var/lib/composepilot/workspace
